      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": ["# Q3:\n"]
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Lets implement RAGBase by our selves to match the new kind of data\n\n",
        "query = \"How does the agentic loop keep calling the model until it stops?\"\n",
        "instructions = \"You are helpful assistant to answer questions from lessons related to our llm-zoomcamp\"\n\n",
        "USER_PROMPT_TEMPLATE = \"\"\"\n",
        "Question:\n",
        "{question}\n\n",
        "Context:\n",
        "{context}\n",
        "\"\"\".strip()\n\n",
        "def build_index(documents):\n",
        "    index = Index(\n",
        "        text_fields=[\"content\"],\n",
        "        keyword_fields=[\"filename\"]\n",
        "    )\n",
        "    index.fit(documents)\n",
        "    return index\n\n",
        "index = build_index(documents)\n\n",
        "class RAGBase:\n",
        "    def __init__(self, \
",
        "                 index, \
",
        "                 prompt_template = USER_PROMPT_TEMPLATE, \
",
        "                 model_name= \"qwen/qwen3-32b\", \
",
        "                 filename = \"filename\"\n",
        "                 ):\n\n",
        "        self.index = index\n",
        "        self.query = query\n",
        "        self.prompt_template=USER_PROMPT_TEMPLATE\n",
        "        self.instructions = instructions\n",
        "        self.model_name = model_name\n",
        "        self.filenmae = filename\n\n",
        "    def search(self, query, num_results = 5):\n",
        "        \"\"\"\n",
        "        To return the top 3 matching results from  similarity score\n",
        "        \"\"\"\n",
        "        boost_dict = {\"content\":1}\n",
        "        filter_dict = {\"filename\": self.filenmae}\n\n",
        "        return self.index.search(query=query,  \n",
        "                                 num_results=num_results,\n",
        "                                 boost_dict=boost_dict,\n",
        "                                 filter_dict=filter_dict\n",
        "                                 )\n\n",
        "    def build_context(self, search_results):\n",
        "        lines  = []\n\n",
        "        for item in search_results:\n",
        "            lines.append(\"Content:\" + item[\"content\"])\n",
        "            lines.append(\"\")\n\n",
        "        return \"\n\".join(lines).strip()\n\n",
        "    def build_prompt(self, query, search_results):\n",
        "        context = self.build_context(search_results=search_results)\n",
        "        prompt = self.prompt_template.format(query=query, context=context)\n",
        "        return prompt\n\n",
        "    def llm(self, model_name, prompt):\n",
        "        message_history = [\n",
        "            {\"role\": \"system\", \"content\": self.instructions},\n",
        "            {\"role\": \"user\", \"content\": prompt}\n",
        "        ]\n\n",
        "        llm_model = ChatGroq(model_name, temperature=0)\n\n",
        "        response = llm_model.invoke(message_history)\n",
        "        return response.content\n\n",
        "    def RAG(self, query, model_name):\n",
        "        search_results = self.search(query=query)\n",
        "        prompt = self.build_prompt(query, search_results)\n",
        "        answer = self.llm(prompt, model_name)\n\n",
        "        return answer\n"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "index= build_index(documents=documents)\n",
        "index.search(query=query)\n"
      ]
    },
